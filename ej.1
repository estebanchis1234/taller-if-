#include <iostream>
using namespace std;

int main() {
    int anio;

    cout << "Ingrese un año: ";
    cin >> anio;

    if (anio % 400 == 0) {
        cout << "El año es bisiesto" << endl;
    } 
    else if (anio % 100 == 0) {
        cout << "El año no es bisiesto" << endl;
    } 
    else if (anio % 4 == 0) {
        cout << "El año es bisiesto" << endl;
    } 
    else {
        cout << "El año no es bisiesto" << endl;
    }

    return 0;
}
